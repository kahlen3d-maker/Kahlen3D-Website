# --- Kontaktformular / E-Mail-Versand -------------------------------------
# Kopiere diese Datei zu ".env.local" und trage deine Werte ein.
# (Die Datei .env.local wird NICHT eingecheckt.)

# SMTP-Server. Für Gmail unverändert lassen:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Deine Gmail-Adresse:
SMTP_USER=kahlen3d@gmail.com

# WICHTIG: NICHT dein normales Passwort, sondern ein "App-Passwort".
# Gmail: Google-Konto -> Sicherheit -> Bestätigung in zwei Schritten aktivieren
# -> danach unter "App-Passwörter" ein 16-stelliges Passwort erzeugen und hier einfügen.
SMTP_PASS=xxxxxxxxxxxxxxxx

# Empfänger der Anfragen (optional; Standard = SMTP_USER):
CONTACT_TO=kahlen3d@gmail.com

# Absender (optional; Standard = SMTP_USER). Bei Gmail muss dies die eigene Adresse sein.
CONTACT_FROM=kahlen3d@gmail.com
